    })
  ]],
  Documentation = "Jump to Pacific Ocean splashdown off San Diego",
  GuiPath = "/Artemis2/Events",
  IsLocal = false
}


asset.onInitialize(function()
  openspace.action.registerAction(SetupLaunch)
  openspace.action.registerAction(GoToLiftoff)
  openspace.action.registerAction(GoToICPSSep)
  openspace.action.registerAction(GoToTLI)
  openspace.action.registerAction(GoToLunarSOI)
  openspace.action.registerAction(GoToClosestApproach)
  openspace.action.registerAction(GoToMaxDistance)
  openspace.action.registerAction(GoToExitLunarSOI)
  openspace.action.registerAction(GoToEntryInterface)
  openspace.action.registerAction(GoToSplashdown)
end)

asset.onDeinitialize(function()
  openspace.action.removeAction(GoToSplashdown)
  openspace.action.removeAction(GoToEntryInterface)
  openspace.action.removeAction(GoToExitLunarSOI)
  openspace.action.removeAction(GoToMaxDistance)
  openspace.action.removeAction(GoToClosestApproach)
  openspace.action.removeAction(GoToLunarSOI)
  openspace.action.removeAction(GoToTLI)
  openspace.action.removeAction(GoToICPSSep)
  openspace.action.removeAction(GoToLiftoff)
  openspace.action.removeAction(SetupLaunch)
end)

asset.export("SetupLaunch", SetupLaunch.Identifier)
asset.export("GoToLiftoff", GoToLiftoff.Identifier)
asset.export("GoToICPSSep", GoToICPSSep.Identifier)
asset.export("GoToTLI", GoToTLI.Identifier)
asset.export("GoToLunarSOI", GoToLunarSOI.Identifier)
asset.export("GoToClosestApproach", GoToClosestApproach.Identifier)
asset.export("GoToMaxDistance", GoToMaxDistance.Identifier)
asset.export("GoToExitLunarSOI", GoToExitLunarSOI.Identifier)
asset.export("GoToEntryInterface", GoToEntryInterface.Identifier)
asset.export("GoToSplashdown", GoToSplashdown.Identifier)


asset.meta = {
  Name = "Actions - Artemis 2",
  Description = "Actions related to the Artemis 2 mission",
  Author = "Custom",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
