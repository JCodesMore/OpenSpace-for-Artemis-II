  Identifier = "os.artemis2.GoToSplashdown",
  Name = "Go to Splashdown",
  Command = [[
    openspace.time.setTime("2026-04-11T00:21:00.000")
    openspace.navigation.setNavigationState({
      Anchor = "Artemis2Model",
      Position = { 0.0, 50000.0, 100000.0 },
      ReferenceFrame = "Root",
