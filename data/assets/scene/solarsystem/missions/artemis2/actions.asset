local SetupLaunch = {
  Identifier = "os.artemis2.SetupLaunch",
  Name = "Set to Artemis-2 launch time",
  Command = [[openspace.time.setTime("2026-04-01T22:24:00.000")]],
  Documentation = "Set the time to the launch time of Artemis-2",
  GuiPath = "/Artemis2",
  IsLocal = false
}


asset.onInitialize(function()
  openspace.action.registerAction(SetupLaunch)
end)

asset.onDeinitialize(function()
  openspace.action.removeAction(SetupLaunch)
end)

asset.export("SetupLaunch", SetupLaunch.Identifier)



asset.meta = {
  Name = "Actions - Artemis 2",
  Description = "Actions related to the Artemis 2 mission",
  Author = "Custom",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
