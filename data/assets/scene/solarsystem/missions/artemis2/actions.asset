local SetupLaunch = {
  Identifier = "os.artemis2.SetupLaunch",
  Name = "Set to Artemis-2 launch time",
  Command = [[openspace.time.setTime("2026-04-01T22:24:00.000")]],
  Documentation = "Set the time to the launch time of Artemis-2",
  GuiPath = "/Artemis2",
  IsLocal = false
}

local GoToLiftoff = {
  Identifier = "os.artemis2.GoToLiftoff",
  Name = "Go to Liftoff",
  Command = [[
    openspace.time.setTime("2026-04-01T22:35:00.000")
    openspace.navigation.setNavigationState({
      Anchor = "Artemis2Model",
      Position = { 0.0, 50000.0, 100000.0 },
      ReferenceFrame = "Root",
      Up = { 0.0, 1.0, 0.0 }
    })
  ]],
  Documentation = "Jump to SLS liftoff from KSC LC-39B",
  GuiPath = "/Artemis2/Events",
  IsLocal = false
}

