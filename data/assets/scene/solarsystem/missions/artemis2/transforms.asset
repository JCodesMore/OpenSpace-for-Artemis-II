local earthTransforms = asset.require("scene/solarsystem/planets/earth/transforms")

local Artemis2Position = {
  Identifier = "Artemis2Position",
  Parent = earthTransforms.EarthCenter.Identifier,
  Transform = {
    Translation = {
      Type = "HorizonsTranslation",
      HorizonsTextFile = asset.resource("artemis2.hrz")
    }
  },
  GUI = {
    Name = "Artemis-2 Position",
    Path = "/Solar System/Missions/Artemis",
    Focusable = false,
    Hidden = true
  }
}

asset.onInitialize(function()
  openspace.addSceneGraphNode(Artemis2Position)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(Artemis2Position)
end)

asset.export(Artemis2Position)

asset.meta = {
  Name = "Artemis-2 Transforms",
  Description = "Artemis-2 position node using pre-computed Horizons trajectory",
  Author = "Custom",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
